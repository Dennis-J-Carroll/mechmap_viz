# Railway deployment environment variables
# Copy to .env for local dev, set in Railway dashboard for production

# SQLite database — in Railway, mount a Volume at /data and use this path
DATABASE_URL="file:/data/mechmap.db"

# Next.js standalone server binds to this hostname
# Must be 0.0.0.0 on Railway (not 127.0.0.1)
HOSTNAME="0.0.0.0"

# Railway sets PORT automatically — do not override in Railway dashboard
# PORT=3000
